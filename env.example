# =============================================================================
# ПЕРЕМЕННЫЕ ОКРУЖЕНИЯ AI-ПОМОЩНИКА ОНКОЛОГА
# =============================================================================
# Скопируйте этот файл в .env и заполните реальными значениями
# НИКОГДА не коммитьте .env с реальными учётными данными в репозиторий!
# =============================================================================

# -----------------------------------------------------------------------------
# YANDEX CLOUD - Аутентификация
# -----------------------------------------------------------------------------
# Получите доступ к Yandex Cloud: https://cloud.yandex.ru/docs/iam/operations/api-key/create

# ID каталога (обязательно)
# Получить через: yc resource-manager folder list
YC_FOLDER_ID=b1cxxxxxxxxxxxxxxxxxxxxxxxxxx

# -----------------------------------------------------------------------------
# Способ 1: IAM-токен (для локальной разработки)
# -----------------------------------------------------------------------------
# Получить через: yc iam create-token
# Срок действия: 1 час
YC_IAM_TOKEN=t1.xxxxxxxxxxxxxxxxxxxx

# -----------------------------------------------------------------------------
# Способ 2: Сервисный аккаунт (рекомендуется для продакшена)
# -----------------------------------------------------------------------------
# Создайте сервисный аккаунт с ролью ai.languageModels.user
# yc iam service-account create --name oncology-assistant
# yc iam service-account add-role --role ai.languageModels.user --service-account-name oncology-assistant
# yc iam key create --service-account-name oncology-assistant --output authorized_key.json
YC_SERVICE_ACCOUNT_KEY=credentials/authorized_key.json

# -----------------------------------------------------------------------------
# Способ 3: API-ключ (ограниченные возможности)
# -----------------------------------------------------------------------------
YC_API_KEY=

# -----------------------------------------------------------------------------
# НАСТРОЙКИ ПРИЛОЖЕНИЯ
# -----------------------------------------------------------------------------
LOG_LEVEL=INFO
CONFIG_PATH=config/config.yaml

# -----------------------------------------------------------------------------
# НАСТРОЙКИ СЕРВЕРА
# -----------------------------------------------------------------------------
HOST=0.0.0.0
PORT=8000
DEBUG=false
WORKERS=4

# -----------------------------------------------------------------------------
# НАСТРОЙКИ БЕЗОПАСНОСТИ
# -----------------------------------------------------------------------------
REQUIRE_ANONYMIZATION=true
MAX_FILE_SIZE=52428800

# -----------------------------------------------------------------------------
# БАЗА ЗНАНИЙ
# -----------------------------------------------------------------------------
KNOWLEDGE_BASE_DIR=knowledge_base_data/minzdrav
RAG_INDEX_DIR=knowledge_base_data/index
EMBEDDING_MODEL=sentence-transformers/ruBert-large

# -----------------------------------------------------------------------------
# OCR НАСТРОЙКИ
# -----------------------------------------------------------------------------
OCR_USE_GPU=false
OCR_LANGUAGES=ru,en

# -----------------------------------------------------------------------------
# ИНТЕРФЕЙСЫ
# -----------------------------------------------------------------------------
DOCTOR_INTERFACE_PORT=8501
PATIENT_INTERFACE_PORT=8502
