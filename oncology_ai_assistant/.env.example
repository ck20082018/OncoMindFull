# =============================================================================
# OncoMind - AI Configuration
# =============================================================================
# Скопируйте этот файл в .env и заполните значениями

# -----------------------------------------------------------------------------
# Yandex Cloud Configuration
# -----------------------------------------------------------------------------

# ID каталога в Yandex Cloud (начинается с b1c...)
# Получить: yc resource-manager folder list
YC_FOLDER_ID=b1cxxxxxxxxxxxxxxxxxxxxxxxxxx

# Путь к файлу сервисного аккаунта (относительно этой папки)
# Создать: yc iam key create --service-account-name oncomind-ai --output oncomind_sa_key.json
YC_SERVICE_ACCOUNT_KEY=oncomind_sa_key.json

# IAM токен для тестов (действует 1 час)
# Получить: yc iam create-token --key-file oncomind_sa_key.json
# Закомментируйте или удалите эту строку для продакшена
YC_IAM_TOKEN=t1.xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# -----------------------------------------------------------------------------
# AI Server Configuration
# -----------------------------------------------------------------------------

# Порт AI сервера (FastAPI)
AI_PORT=8000

# Хост для сервера
AI_HOST=0.0.0.0

# Режим отладки (True/False)
DEBUG=True

# -----------------------------------------------------------------------------
# Database Configuration (если нужно)
# -----------------------------------------------------------------------------

# Database URL (SQLite по умолчанию)
DATABASE_URL=sqlite:///./oncomind_ai.db

# -----------------------------------------------------------------------------
# Logging Configuration
# -----------------------------------------------------------------------------

# Уровень логирования: DEBUG, INFO, WARNING, ERROR, CRITICAL
LOG_LEVEL=INFO

# Путь к файлу логов
LOG_FILE=logs/oncomind_ai.log
